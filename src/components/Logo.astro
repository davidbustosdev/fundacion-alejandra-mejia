---
import Image from "astro/components/Image.astro";
import { SITE_TITLE } from "../consts";
const { mode = "light" } = Astro.props;
const [first, ...rest] = SITE_TITLE.split(" ");
const lastName = rest.join(" ");
---

<a href="/" class="logo flex items-center gap-2 sm:gap-3">
  <svg
    width="52"
    height="52"
    viewBox="0 0 512 512"
    xmlns="http://www.w3.org/2000/svg"
    class="shrink-0"
  >
    <defs>
      <linearGradient id="heartGradient" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="#3BAFDA" />
        <stop offset="100%" stop-color="#48CFAD" />
      </linearGradient>
    </defs>

    <circle cx="256" cy="256" r="220" fill="#F8FAFC" />

    <path
      d="M140 290 C110 260, 105 210, 140 185 C165 165, 200 170, 220 195 L256 240 L220 295 C200 325, 165 325, 140 290Z"
      fill="#3BAFDA"
    />

    <path
      d="M372 290 C402 260, 407 210, 372 185 C347 165, 312 170, 292 195 L256 240 L292 295 C312 325, 347 325, 372 290Z"
      fill="#48CFAD"
    />

    <path
      d="M256 355 C180 300, 145 260, 145 210 C145 165, 180 135, 220 135 C240 135, 252 145, 256 155 C260 145, 272 135, 292 135 C332 135, 367 165, 367 210 C367 260, 332 300, 256 355Z"
      fill="url(#heartGradient)"
    />

    <circle cx="256" cy="215" r="18" fill="#FFFFFF" />
    <path
      d="M226 275 C226 245, 286 245, 286 275 L286 295 L226 295Z"
      fill="#FFFFFF"
    />
  </svg>

  <span class="flex flex-col leading-tight">
    <span class="text-xs sm:text-sm font-bold tracking-wide">{first}</span>
    <span class="text-sm sm:text-base font-bold tracking-wide">{lastName}</span>
  </span>
</a>
