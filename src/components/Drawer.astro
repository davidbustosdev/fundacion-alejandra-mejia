---
import { NAV_MENU } from "../consts";
import Logo from "./Logo.astro";
---

<div class="drawer-side">
  <label for="my-drawer-2" aria-label="close sidebar" class="drawer-overlay">
    <span class="sr-only">Close</span>
  </label>
  <div class="menu bg-dark text-white min-h-full w-80 p-4">
    <Logo mode="dark" />
    <ul class="mt-4">
      {NAV_MENU.map((item) => (
        <li>
          <a
            href={item.url}
            class="hover:bg-black/30 text-white block py-2 px-3 rounded-lg transition-colors"
            data-i18n={item.key}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</div>
