---
import { Image } from "astro:assets";
---

<section
  id="inicio"
  class="min-h-screen flex items-center bg-no-repeat bg-cover relative overflow-hidden pt-20"
>
  <Image
    src="/img/bg/bg0.webp"
    alt=""
    width={1920}
    height={1080}
    loading="eager"
    fetchpriority="high"
    format="webp"
    quality={50}
    class="absolute inset-0 w-full h-full object-cover -z-20"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-black/70 to-black/40 -z-10"></div>
  <div class="container z-10">
    <div class="max-w-2xl text-center sm:text-left">
      <h1 class="text-white" data-i18n="hero.title">
        Transformando vidas con amor, inclusión y oportunidades
      </h1>
      <p class="text-lg text-gray-200 mt-4 mb-8" data-i18n="hero.subtitle">
        Trabajamos para brindar apoyo a quienes más lo necesitan...
      </p>
      <div class="flex flex-wrap gap-4 justify-center sm:justify-start">
        <a
          href="#contacto"
          class="btn bg-main border-main text-white rounded-lg hover:bg-green-600 px-6"
          data-i18n="hero.cta1"
        >
          ¿Cómo puedo ayudar?
        </a>
        <a
          href="#nosotros"
          class="btn btn-outline border-white text-white hover:bg-white/10 rounded-lg px-6"
          data-i18n="hero.cta2"
        >
          Conócenos
        </a>
      </div>
    </div>
  </div>
</section>
