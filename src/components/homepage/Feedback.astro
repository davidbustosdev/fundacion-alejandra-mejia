---
import { Image } from "astro:assets";

const testimonios = [
  {
    name: "María Rodríguez",
    role: "Beneficiaria",
    text: "La Fundación Alejandra Mejía cambió mi vida. Gracias a su apoyo, mi familia hoy tiene una oportunidad real de salir adelante. El acompañamiento que nos brindaron fue invaluable.",
    img: "/img/comments/cmnt1.webp",
  },
  {
    name: "Juan Pérez",
    role: "Voluntario",
    text: "Ser parte de esta fundación me ha permitido ver el impacto real que podemos tener cuando nos unimos por una causa. El trabajo con la comunidad es inspirador y transformador.",
    img: "/img/comments/cmnt1.webp",
  },
  {
    name: "Ana Martínez",
    role: "Beneficiaria",
    text: "Gracias a los programas de inclusión laboral, encontré un empleo digno que me permite mantener a mis hijos. La fundación no solo da ayuda, devuelve la esperanza.",
    img: "/img/comments/cmnt1.webp",
  },
];
---

<section id="testimonios" class="section">
  <div class="container">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 data-i18n="testimonios.title">Testimonios</h2>
      <p class="text-gray-600 dark:text-gray-300" data-i18n="testimonios.desc">
        Conoce las historias de quienes han sido impactados por nuestra labor.
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonios.map((t) => (
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl p-6 shadow-sm dark:shadow-none relative border-t-4 border-t-main">
          <div class="flex items-center gap-3 mb-4">
            <Image
              src={t.img}
              alt={t.name}
              width={60}
              height={60}
              format="webp"
              quality={45}
              class="w-12 h-12 rounded-full object-cover"
            />
            <div>
              <p class="font-semibold">{t.name}</p>
              <p class="text-sm text-gray-500 dark:text-gray-400">{t.role}</p>
            </div>
          </div>
          <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">"{t.text}"</p>
          <div class="flex gap-1 mt-3 text-yellow-400">
            {Array.from({ length: 5 }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
