---
import { Image } from "astro:assets";

const team = [
  {
    name: "Alejandra Mejía",
    role: "Directora Fundadora",
    img: "/img/team/team1.jpg",
  },
  {
    name: "María García",
    role: "Coordinadora de Programas",
    img: "/img/team/team2.jpg",
  },
  {
    name: "Carlos López",
    role: "Director de Operaciones",
    img: "/img/team/team3.jpg",
  },
];
---

<section id="equipo" class="section section-alt">
  <div class="container">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 data-i18n="equipo.title">Nuestro Equipo</h2>
      <p class="text-gray-600 dark:text-gray-300" data-i18n="equipo.desc">
        Conoce a las personas apasionadas que hacen posible nuestra misión cada día.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      {team.map((member) => (
        <div class="bg-white dark:bg-gray-800 rounded-xl overflow-hidden shadow-sm hover:shadow-md dark:shadow-none dark:hover:shadow-gray-700/50 transition-shadow text-center">
          <Image
            src={member.img}
            alt={member.name}
            width={400}
            height={400}
            format="webp"
            quality={45}
            class="w-full h-64 object-cover"
          />
          <div class="p-5">
            <h3 class="text-xl font-semibold mb-1">{member.name}</h3>
            <p class="text-gray-500 dark:text-gray-400 text-sm">{member.role}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
