---
import TeamCard from "../card/TeamCard.astro";
import { getCollection } from "astro:content";

const team = (await getCollection("team"))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);
---

<section class="section section-services">
    <div class="container">
        <div
            class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-4 border-b border-b-main pb-10"
        >
            <h2 class="capitalize">Nuestra Misión</h2>
            <div>
                <p class="mb-3">
                    Trabajar por el bienestar de las familias en situación de
                    vulnerabilidad, brindando apoyo social, acompañamiento y
                    oportunidades de desarrollo, mientras promovemos la
                    inclusión de personas con discapacidad y la generación de
                    empleo digno mediante proyectos productivos sostenibles.
                </p>
            </div>
        </div>
        <div
            class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-10 mt-10 relative"
        >
            {team.map((people) => <TeamCard {...people} />)}
        </div>
    </div>
</section>
