---
import { Image } from "astro:assets";
---

<section id="nosotros" class="section">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
      <div>
        <h2 data-i18n="nosotros.title">Nuestra Visión</h2>
        <p class="text-gray-600 dark:text-gray-300 leading-relaxed" data-i18n="nosotros.desc">
          Ser una fundación reconocida por transformar vidas...
        </p>
      </div>
      <div class="flex justify-center">
        <Image
          src="/img/img1.webp"
          alt=""
          width="478"
          height="421"
          format="webp"
          quality={45}
          class="rounded-2xl object-cover shadow-lg"
        />
      </div>
    </div>
  </div>
</section>
