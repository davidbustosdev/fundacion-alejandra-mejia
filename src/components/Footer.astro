---
const today = new Date();
import Logo from "./Logo.astro";
---

<footer class="footer bg-dark text-white gap-0 block">
  <div class="w-full py-16">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10">
        <div>
          <Logo mode="dark" />
          <p class="mt-4 text-sm text-gray-300" data-i18n="footer.desc">
            Trabajamos por el bienestar de las familias colombianas...
          </p>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-4" data-i18n="footer.nav.title">
            Enlaces
          </h3>
          <nav class="grid gap-2 text-sm">
            <a href="#inicio" class="hover:text-main transition-colors" data-i18n="nav.inicio">Inicio</a>
            <a href="#nosotros" class="hover:text-main transition-colors" data-i18n="nav.nosotros">Nosotros</a>
            <a href="#mision" class="hover:text-main transition-colors" data-i18n="nav.mision">Misión</a>
            <a href="#programas" class="hover:text-main transition-colors" data-i18n="nav.programas">Programas</a>
            <a href="#contacto" class="hover:text-main transition-colors" data-i18n="nav.contacto">Contacto</a>
          </nav>
        </div>
        <div>
          <h3 class="text-lg font-semibold mb-4" data-i18n="footer.contact.title">
            Contacto
          </h3>
          <ul class="grid gap-2 text-sm text-gray-300">
            <li data-i18n="contacto.phone">+57 xxx xxx xx xx</li>
            <li data-i18n="contacto.mail">info@fundacionalejandramejia.org</li>
            <li data-i18n="contacto.addr">Bogotá, Colombia</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
  <div class="border-t border-white/20 w-full">
    <div class="container text-center py-6 text-sm text-gray-400">
      &copy; {today.getFullYear()} Fundación Alejandra Mejía.
      <span data-i18n="footer.copyright">Todos los derechos reservados.</span>
    </div>
  </div>
</footer>
